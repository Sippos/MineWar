extends Node

const SHELL_BASE64 := ""

func _ready() -> void:
	var shell := Marshalls.base64_to_utf8(SHELL_BASE64)
	var file := FileAccess.open("res://web_compatibility_shell.html", FileAccess.WRITE)
	if file == null:
		printerr("WEB_SHELL_WRITE_FAILED")
		get_tree().quit(1)
		return
	file.store_string(shell)
	file.close()
	print("WEB_SHELL_WRITTEN bytes=", shell.to_utf8_buffer().size())
	get_tree().quit()
